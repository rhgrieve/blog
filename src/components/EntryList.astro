---
import FormattedDate from './FormattedDate.astro';
import { isVisible } from '../lib/drafts';

interface Entry {
  id: string;
  data: {
    title: string;
    date: Date;
    summary?: string;
    draft?: boolean;
  };
}

interface Props {
  entries: Entry[];
  basePath: string;
  showSummary?: boolean;
  feedName?: string;
}

const { entries, basePath, showSummary = false, feedName } = Astro.props;

const published = entries
  .filter(isVisible)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

{published.length === 0 && <p class="dim">Nothing here yet.</p>}

<ul class="h-feed entry-list">
  {feedName && <span class="p-name" hidden>{feedName}</span>}
  <div class="p-author h-card" hidden>
    <img class="u-photo" src="/avatar.png" alt="rhg" />
    <a class="p-name u-url" href="https://rhg.sh">rhg</a>
  </div>
  {published.map((entry) => (
    <li class="h-entry">
      <a href={`${basePath}/${entry.id}`} class="u-url">
        <span class="p-name entry-title">
          {entry.data.draft && <span class="draft-badge">draft</span>}
          {entry.data.title}
        </span>
        <span class="entry-date mono">
          <FormattedDate date={entry.data.date} class="dt-published" />
        </span>
      </a>
      {showSummary && entry.data.summary && (
        <p class="p-summary entry-summary">{entry.data.summary}</p>
      )}
    </li>
  ))}
</ul>

<style>
  .entry-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .entry-list li a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.45rem 0;
    color: var(--text);
    transition: color 0.12s ease, transform 0.12s ease, text-shadow 0.12s ease;
  }

  .entry-list li a:hover {
    color: var(--text-bright);
    transform: translateX(2px);
    text-shadow: 0 0 8px var(--accent-glow);
  }

  .entry-list li a:hover .entry-date {
    opacity: 0.8;
  }

  .entry-title {
    flex: 1;
    min-width: 0;
  }

  .entry-date {
    flex-shrink: 0;
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .draft-badge {
    color: #f0c040;
    border: 1px solid #f0c040;
    border-radius: 3px;
    padding: 0.05rem 0.4rem;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    margin-right: 0.4rem;
  }

  .entry-summary {
    font-size: 0.84rem;
    color: var(--text-dim);
    margin: 0.15rem 0 0.6rem;
    max-width: var(--measure);
  }
</style>
