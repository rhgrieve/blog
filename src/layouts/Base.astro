---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site.' } = Astro.props;
const siteTitle = 'rhg';
const pageTitle = title === 'Home' ? siteTitle : `${title} — ${siteTitle}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <link rel="authorization_endpoint" href="https://indieauth.com/auth" />
    <link rel="token_endpoint" href="https://tokens.indieauth.com/token" />
    <link rel="me" href="https://rhg.sh" />
    <link rel="preconnect" href="https://rsms.me/" crossorigin />
    <link rel="preload" href="https://rsms.me/inter/inter.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://rsms.me/inter/inter.css" /></noscript>
    <ClientRouter />
  </head>
  <body>
    <canvas id="glow-canvas" aria-hidden="true" transition:persist></canvas>
    <div class="container">
      <header class="site-header">
        <nav>
          <a href="/" class="site-name">{siteTitle}</a>
          <div class="nav-links">
            <a href="/writing">Writing</a>
            <a href="/notes">Notes</a>
            <a href="/projects">Projects</a>
            <a href="/about">About</a>
            <a href="/activity">Activity</a>
            <button id="glow-toggle" class="glow-toggle" aria-label="Toggle light effect">
              <span class="glow-toggle-dot"></span>
            </button>
          </div>
        </nav>
      </header>

      <main transition:animate="fade">
        <slot />
      </main>

      <footer class="site-footer">
        <span class="dim mono">&copy; {new Date().getFullYear()}</span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .site-header nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
  }

  .site-name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: -0.02em;
    transition: color 0.12s ease, letter-spacing 0.12s ease, text-shadow 0.12s ease;
  }
  .site-name:hover {
    color: var(--text-bright);
    letter-spacing: 0.01em;
    text-shadow: 0 0 12px var(--accent-glow);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    font-size: 0.8rem;
    color: var(--text-dim);
    transition: color 0.12s ease, text-shadow 0.12s ease;
  }
  .nav-links a:hover {
    color: var(--text);
    text-shadow: 0 0 8px var(--accent-glow);
  }

  .glow-toggle {
    background: none;
    border: none;
    padding: 0.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    margin-left: 0.25rem;
  }

  .glow-toggle-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.4;
    transition: opacity 0.15s ease, background 0.15s ease;
  }

  .glow-toggle:hover .glow-toggle-dot {
    opacity: 0.7;
  }

  .glow-toggle[data-off] .glow-toggle-dot {
    background: var(--text-dim);
    opacity: 0.2;
  }

  .site-footer {
    padding: 2.5rem 0;
    margin-top: auto;
    text-align: right;
  }

  #glow-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: screen;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9998;
    mix-blend-mode: color;
    background: radial-gradient(
      ellipse 70% 55% at var(--glow-x, 50%) var(--glow-y, 50%),
      rgba(240, 100, 220, 0.07) 0%,
      transparent 70%
    );
    opacity: var(--glow-visible, 0);
    transition: opacity 0.6s ease;
  }

</style>

<script>
  const canvas = document.getElementById('glow-canvas') as HTMLCanvasElement;
  const toggle = document.getElementById('glow-toggle') as HTMLButtonElement;
  if (canvas && window.matchMedia('(pointer: fine)').matches) {
    const ctx = canvas.getContext('2d')!;
    let enabled = localStorage.getItem('glow') !== 'off';

    function applyToggleState() {
      if (enabled) {
        toggle?.removeAttribute('data-off');
      } else {
        toggle?.setAttribute('data-off', '');
        canvas.style.opacity = '0';
        document.body.style.setProperty('--glow-visible', '0');
      }
    }

    applyToggleState();

    toggle?.addEventListener('click', () => {
      enabled = !enabled;
      localStorage.setItem('glow', enabled ? 'on' : 'off');
      applyToggleState();
      if (enabled) {
        visible = true;
        canvas.style.opacity = '1';
        document.body.style.setProperty('--glow-visible', '1');
      }
    });

    // noise function — layered sine waves for organic distortion
    function noise(x: number, y: number, t: number): number {
      return (
        Math.sin(x * 1.3 + t) * Math.sin(y * 0.9 + t * 0.7) * 0.5 +
        Math.sin(x * 2.7 - t * 0.4) * Math.sin(y * 1.8 + t * 1.1) * 0.3 +
        Math.sin(x * 0.7 + y * 1.1 + t * 0.3) * 0.2
      );
    }

    // render at quarter resolution for performance
    const scale = 4;
    let bw = 0, bh = 0;
    let offscreen: OffscreenCanvas | null = null;
    let offCtx: OffscreenCanvasRenderingContext2D | null = null;

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      bw = Math.ceil(canvas.width / scale);
      bh = Math.ceil(canvas.height / scale);
      offscreen = new OffscreenCanvas(bw, bh);
      offCtx = offscreen.getContext('2d')!;
    }

    resize();
    window.addEventListener('resize', resize);

    let mx = 0.5, my = 0.5;
    let gx = 0.5, gy = 0.5;
    let visible = false;
    const ease = 0.05;
    let time = 0;

    document.addEventListener('mousemove', (e) => {
      mx = e.clientX / window.innerWidth;
      my = e.clientY / window.innerHeight;
      if (!visible && enabled) {
        visible = true;
        canvas.style.opacity = '1';
        document.body.style.setProperty('--glow-visible', '1');
      }
    });

    document.addEventListener('mouseleave', () => {
      visible = false;
      canvas.style.opacity = '0';
      document.body.style.setProperty('--glow-visible', '0');
    });

    (function tick() {
      gx += (mx - gx) * ease;
      gy += (my - gy) * ease;
      time += 0.008;

      // update CSS tint layer position
      document.body.style.setProperty('--glow-x', `${gx * 100}%`);
      document.body.style.setProperty('--glow-y', `${gy * 100}%`);

      if (!offCtx || !offscreen) { requestAnimationFrame(tick); return; }

      // render the light blob at low resolution
      const img = offCtx.createImageData(bw, bh);
      const d = img.data;
      const centerX = gx * bw;
      const centerY = gy * bh;
      // asymmetric radii — wider than tall
      const rx = bw * 0.7;
      const ry = bh * 0.55;

      for (let y = 0; y < bh; y++) {
        for (let x = 0; x < bw; x++) {
          // normalized distance with elliptical shape
          const ndx = (x - centerX) / rx;
          const ndy = (y - centerY) / ry;
          let dist = Math.sqrt(ndx * ndx + ndy * ndy);

          // noise distortion — warp the distance field
          const n = noise(x * 0.02, y * 0.02, time) * 0.25;
          dist += n;

          // cubic falloff
          const t = Math.min(Math.max(dist, 0), 1);
          const alpha = (1 - t) * (1 - t) * (1 - t) * 0.08;

          // dither to break 8-bit banding
          const dither = (Math.random() - 0.5) * (2 / 255);
          const a = Math.max(0, Math.min(1, alpha + dither));

          const i = (y * bw + x) * 4;
          d[i]     = 240;
          d[i + 1] = 100;
          d[i + 2] = 220;
          d[i + 3] = Math.round(a * 255);
        }
      }

      offCtx.putImageData(img, 0, 0);

      // scale up to full canvas with bilinear filtering
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(offscreen, 0, 0, canvas.width, canvas.height);

      requestAnimationFrame(tick);
    })();
  }
</script>
