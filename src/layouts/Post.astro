---
import Base from './Base.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
  title: string;
  date: Date;
  summary?: string;
  tags?: string[];
  draft?: boolean;
}

const { title, date, summary, tags = [], draft = false } = Astro.props;
---

<Base title={title} description={summary}>
  <article class="h-entry">
    <header class="post-header">
      <h1 class="p-name">{title}</h1>
      <div class="post-meta mono">
        {draft && <span class="draft-badge">draft</span>}
        <FormattedDate date={date} class="dt-published" />
        {tags.length > 0 && (
          <span class="tags">
            {tags.map((tag) => (
              <a class="tag p-category" href={`/tags/${tag}/`}>{tag}</a>
            ))}
          </span>
        )}
      </div>
      {summary && <p class="p-summary" hidden>{summary}</p>}
    </header>
    <div class="e-content prose">
      <slot />
    </div>
    <div class="p-author h-card" hidden>
      <img class="u-photo" src="/avatar.png" alt="rhg" />
      <a class="p-name u-url" href="https://rhg.sh">rhg</a>
    </div>
    <a class="u-url" href={Astro.url.pathname} hidden></a>
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 3.5rem;
  }

  .post-header h1 {
    margin-bottom: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 0.1rem;
    color: var(--text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.015em;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
    text-shadow: 0 0 10px var(--accent-glow);
  }
  .tag::before {
    content: '#';
  }

  .draft-badge {
    color: #f0c040;
    border: 1px solid #f0c040;
    border-radius: 3px;
    padding: 0.05rem 0.4rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
  }
</style>
