---
import Base from '../layouts/Base.astro';
import { getRecentListens, type Listen } from '../lib/spotify';
import { getRecentActivity, type GitHubActivity } from '../lib/github';
import { getRecentHealth, type HealthEvent } from '../lib/health';

const listens = await getRecentListens(200);
const githubActivity = await getRecentActivity(30);
const healthEvents = await getRecentHealth(100);

// unified timeline entry
type TimelineItem =
  | { kind: 'listen'; data: Listen; timestamp: Date }
  | { kind: 'github'; data: GitHubActivity; timestamp: Date };

const items: TimelineItem[] = [
  ...listens.map((l) => ({ kind: 'listen' as const, data: l, timestamp: l.playedAt })),
  ...githubActivity.map((g) => ({ kind: 'github' as const, data: g, timestamp: g.timestamp })),
].sort((a, b) => b.timestamp.getTime() - a.timestamp.getTime());

// aggregate step counts by day label
const stepsByDay = new Map<string, number>();
for (const h of healthEvents) {
  if (h.type === 'steps' && h.value) {
    const label = relativeDay(h.timestamp);
    stepsByDay.set(label, (stepsByDay.get(label) || 0) + Number(h.value));
  }
}

function relativeDay(date: Date): string {
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 7) return `${days} days ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toLowerCase();
}

function formatTime(date: Date): string {
  return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }).toLowerCase();
}

// collapse consecutive listen runs (>3) into first + "x more" + last
type DisplayItem =
  | TimelineItem
  | { kind: 'listen-collapsed'; first: TimelineItem; last: TimelineItem; hidden: TimelineItem[]; count: number; artistSummary: string };

function collapseRuns(dayItems: TimelineItem[]): DisplayItem[] {
  const result: DisplayItem[] = [];
  let i = 0;

  while (i < dayItems.length) {
    if (dayItems[i].kind !== 'listen') {
      result.push(dayItems[i]);
      i++;
      continue;
    }

    // find the run of consecutive listens
    let runEnd = i;
    while (runEnd < dayItems.length && dayItems[runEnd].kind === 'listen') {
      runEnd++;
    }

    const runLength = runEnd - i;
    if (runLength > 3) {
      const hiddenItems = dayItems.slice(i + 1, runEnd - 1);
      const seen = new Map<string, string>();
      for (const h of hiddenItems) {
        const names = (h as { data: Listen }).data.artist.split(', ');
        for (const name of names) {
          const key = name.toLowerCase().trim();
          if (!seen.has(key)) seen.set(key, name.trim());
        }
      }
      const artists = [...seen.values()];

      let artistSummary: string;
      if (artists.length === 1) {
        artistSummary = artists[0];
      } else if (artists.length === 2) {
        artistSummary = `${artists[0]} and ${artists[1]}`;
      } else {
        artistSummary = `${artists[0]}, ${artists[1]} and more`;
      }

      result.push({
        kind: 'listen-collapsed',
        first: dayItems[i],
        last: dayItems[runEnd - 1],
        hidden: hiddenItems,
        count: runLength - 2,
        artistSummary,
      });
    } else {
      for (let j = i; j < runEnd; j++) {
        result.push(dayItems[j]);
      }
    }
    i = runEnd;
  }

  return result;
}

type GroupedDay = {
  label: string;
  items: DisplayItem[];
};

const groupedRaw: { label: string; items: TimelineItem[] }[] = [];
for (const item of items) {
  const label = relativeDay(item.timestamp);
  const existing = groupedRaw.find((g) => g.label === label);
  if (existing) {
    existing.items.push(item);
  } else {
    groupedRaw.push({ label, items: [item] });
  }
}

const groupedCollapsed: GroupedDay[] = groupedRaw.map((g) => ({
  label: g.label,
  items: collapseRuns(g.items),
}));

function shortRepo(full: string): string {
  return full.includes('/') ? full.split('/')[1] : full;
}

const ghActionIcon: Record<string, string> = {
  push:   '<path fill="currentColor" d="M8.75 11V1.75a.75.75 0 00-1.5 0V11L4.53 8.28a.75.75 0 00-1.06 1.06l3.75 3.75a.75.75 0 001.06 0l3.75-3.75a.75.75 0 00-1.06-1.06L8.75 11z"/>',
  pr:     '<path fill="currentColor" d="M5.5 3.5a2 2 0 10-2.77 1.85v5.3a2 2 0 102.27.01V5.35A2 2 0 005.5 3.5zM4 4.5a1 1 0 11-2 0 1 1 0 012 0zm0 8a1 1 0 11-2 0 1 1 0 012 0zm8.5-1.15a2 2 0 10-2.27-.01V6.5a1.5 1.5 0 00-1.5-1.5H7.5a.75.75 0 010-1.5h1.23A3 3 0 0112 6.5v4.85zM13 12.5a1 1 0 11-2 0 1 1 0 012 0z"/>',
  issue:  '<circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="5" x2="8" y2="8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="11" r=".75" fill="currentColor"/>',
  star:   '<path fill="currentColor" d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>',
  create: '<path fill="currentColor" d="M1.75 2.5a.25.25 0 00-.25.25v10.5c0 .138.112.25.25.25h2.5V10A1.5 1.5 0 015.75 8.5h4.5A1.5 1.5 0 0111.75 10v3.5h2.5a.25.25 0 00.25-.25V6.354a.25.25 0 00-.073-.177l-3.604-3.604a.25.25 0 00-.177-.073H8.75V5a.75.75 0 01-1.5 0V2.5H1.75z"/><path fill="currentColor" d="M10.25 10a.25.25 0 00-.25.25V13.5h-4V10.25A.25.25 0 005.75 10h4.5z"/>',
};

const sneakerIcon = '<path fill="currentColor" d="M1 11.5v-1c0-.83.67-1.5 1.5-1.5h.5l1-3.5C4.2 4.6 5.05 4 6 4h1c.55 0 1 .45 1 1v2.5l3.5 1c1.1.31 2 1.2 2.3 2.3l.2.7H15a1 1 0 011 1v.5a.5.5 0 01-.5.5h-14a.5.5 0 01-.5-.5z"/>';

const spotifyLogo = '<path fill="#1DB954" d="M8 0a8 8 0 100 16A8 8 0 008 0zm3.67 11.54a.5.5 0 01-.68.16c-1.87-1.14-4.22-1.4-6.99-.77a.5.5 0 01-.22-.97c3.03-.69 5.63-.39 7.73.9a.5.5 0 01.16.68zm.98-2.18a.62.62 0 01-.85.2c-2.14-1.31-5.4-1.7-7.93-.93a.62.62 0 01-.36-1.19c2.9-.88 6.5-.45 8.94 1.06a.62.62 0 01.2.86zm.08-2.27C10.5 5.6 6.1 5.46 3.56 6.24a.75.75 0 01-.43-1.43c2.92-.9 7.77-.72 10.84 1.07a.75.75 0 01-.74 1.3l-.5-.09z"/>';
const githubLogo = '<path fill="#8b949e" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>';
---

<Base title="Activity" description="Recent activity.">
  <h1>activity</h1>
  <p class="page-desc">what i've been up to, automatically.</p>

  {items.length === 0 && (
    <div class="empty">
      <p class="dim">no activity data available.</p>
      <p class="dim hint">connect spotify or github to populate this page.</p>
    </div>
  )}

  {groupedCollapsed.length > 0 && (
    <div class="timeline">
      {groupedCollapsed.map((group) => (
        <section class="timeline-day">
          <h2 class="day-label mono">
            {group.label}
            {stepsByDay.has(group.label) && (
              <span class="day-steps">
                <svg viewBox="0 0 16 16" width="11" height="11"><Fragment set:html={sneakerIcon} /></svg>
                {stepsByDay.get(group.label)!.toLocaleString()}
              </span>
            )}
          </h2>
          <div class="day-entries">
            {group.items.map((item) => {
              if (item.kind === 'listen') {
                const l = item.data;
                return (
                  <a href={l.url} class="timeline-entry" target="_blank" rel="noopener">
                    <span class="entry-icon">
                      {l.albumArt ? (
                        <img src={l.albumArt} alt="" width="32" height="32" loading="lazy" />
                      ) : (
                        <span class="icon-placeholder">♫</span>
                      )}
                    </span>
                    <span class="entry-body">
                      <span class="entry-primary">{l.track}</span>
                      <span class="entry-secondary">{l.artist}</span>
                    </span>
                    <span class="entry-meta">
                      <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                      <span class="entry-time mono">{formatTime(item.timestamp)}</span>
                    </span>
                  </a>
                );
              } else if (item.kind === 'github') {
                const g = item.data;
                return (
                  <a href={g.url} class="timeline-entry" target="_blank" rel="noopener">
                    <span class="entry-icon gh-action-icon">
                      <svg viewBox="0 0 16 16" width="16" height="16"><Fragment set:html={ghActionIcon[g.type] || ghActionIcon.push} /></svg>
                    </span>
                    <span class="entry-body">
                      <span class="entry-primary">{g.description}</span>
                      <span class="entry-secondary">{shortRepo(g.repo)}</span>
                    </span>
                    <span class="entry-meta">
                      <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={githubLogo} /></svg>
                      <span class="entry-time mono">{formatTime(item.timestamp)}</span>
                    </span>
                  </a>
                );
              } else {
                // collapsed listen run
                const c = item;
                const first = c.first as { kind: 'listen'; data: Listen; timestamp: Date };
                const last = c.last as { kind: 'listen'; data: Listen; timestamp: Date };
                const fl = first.data;
                const ll = last.data;
                return (
                  <div class="listen-group">
                    <a href={fl.url} class="timeline-entry" target="_blank" rel="noopener">
                      <span class="entry-icon">
                        {fl.albumArt ? (
                          <img src={fl.albumArt} alt="" width="32" height="32" loading="lazy" />
                        ) : (
                          <span class="icon-placeholder">♫</span>
                        )}
                      </span>
                      <span class="entry-body">
                        <span class="entry-primary">{fl.track}</span>
                        <span class="entry-secondary">{fl.artist}</span>
                      </span>
                      <span class="entry-meta">
                        <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                        <span class="entry-time mono">{formatTime(first.timestamp)}</span>
                      </span>
                    </a>

                    <button class="listen-expand" data-expand>
                      <span class="expand-dots">···</span>
                      <span class="expand-label">{c.count} more featuring {c.artistSummary}</span>
                      <span class="expand-dots">···</span>
                    </button>

                    <div class="listen-hidden" data-hidden>
                      {c.hidden.map((h) => {
                        const hl = (h as { kind: 'listen'; data: Listen; timestamp: Date }).data;
                        return (
                          <a href={hl.url} class="timeline-entry" target="_blank" rel="noopener">
                            <span class="entry-icon">
                              {hl.albumArt ? (
                                <img src={hl.albumArt} alt="" width="32" height="32" loading="lazy" />
                              ) : (
                                <span class="icon-placeholder">♫</span>
                              )}
                            </span>
                            <span class="entry-body">
                              <span class="entry-primary">{hl.track}</span>
                              <span class="entry-secondary">{hl.artist}</span>
                            </span>
                            <span class="entry-meta">
                              <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                              <span class="entry-time mono">{formatTime(h.timestamp)}</span>
                            </span>
                          </a>
                        );
                      })}
                    </div>

                    <a href={ll.url} class="timeline-entry" target="_blank" rel="noopener">
                      <span class="entry-icon">
                        {ll.albumArt ? (
                          <img src={ll.albumArt} alt="" width="32" height="32" loading="lazy" />
                        ) : (
                          <span class="icon-placeholder">♫</span>
                        )}
                      </span>
                      <span class="entry-body">
                        <span class="entry-primary">{ll.track}</span>
                        <span class="entry-secondary">{ll.artist}</span>
                      </span>
                      <span class="entry-meta">
                        <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                        <span class="entry-time mono">{formatTime(last.timestamp)}</span>
                      </span>
                    </a>
                  </div>
                );
              }
            })}
          </div>
        </section>
      ))}
    </div>
  )}
</Base>

<style>
  h1 { margin-bottom: 0.5rem; }

  .page-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 3rem;
  }

  .empty {
    padding: 2rem 0;
  }

  .hint {
    font-size: 0.82rem;
    margin-top: 0.5rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-day {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .day-label {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    font-weight: 400;
    margin-bottom: 0.5rem;
    padding-left: 0.1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .day-steps {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .day-entries {
    display: flex;
    flex-direction: column;
  }

  .timeline-entry {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: var(--text);
    transition: transform 0.12s ease, color 0.12s ease;
  }

  .timeline-entry:hover {
    transform: translateX(2px);
    color: var(--text-bright);
  }

  .timeline-entry:hover .entry-meta {
    opacity: 0.8;
  }

  .entry-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .entry-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }

  .gh-action-icon {
    color: var(--text-dim);
  }

  .icon-placeholder {
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .entry-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .entry-primary {
    font-size: 0.88rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .entry-secondary {
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .entry-meta {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: opacity 0.12s ease;
  }

  .entry-time {
    font-size: 0.65rem;
    color: var(--text-dim);
  }

  .source-logo {
    opacity: 0.7;
  }

  .listen-group {
    display: flex;
    flex-direction: column;
  }

  .listen-expand {
    background: none;
    border: none;
    padding: 0.5rem 0;
    margin-left: 2.85rem;
    font-size: 0.72rem;
    color: var(--text-dim);
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    transition: color 0.12s ease;
  }

  .listen-expand:hover {
    color: var(--text);
  }

  .expand-dots {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
  }

  .expand-label {
    font-size: 0.72rem;
  }

  .listen-hidden {
    display: none;
    flex-direction: column;
  }

  .listen-hidden.expanded {
    display: flex;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-expand]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const hidden = btn.nextElementSibling as HTMLElement;
        if (hidden?.classList.contains('expanded')) {
          hidden.classList.remove('expanded');
          (btn as HTMLElement).style.display = '';
        } else {
          hidden?.classList.add('expanded');
          (btn as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
