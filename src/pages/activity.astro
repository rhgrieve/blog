---
import Base from '../layouts/Base.astro';
import { getRecentListens, getRecentGitHub, getRecentHealth } from '../lib/timeline';
import type { SpotifyListen, GitHubEvent, HealthEvent } from '../lib/timeline';

const listens = await getRecentListens(200);
const githubActivity = await getRecentGitHub(30);
const healthEvents = await getRecentHealth(100);

// unified timeline entry
type TimelineItem =
  | { kind: 'listen'; data: SpotifyListen; timestamp: Date }
  | { kind: 'github'; data: GitHubEvent; timestamp: Date };

const items: TimelineItem[] = [
  ...listens.map((l) => ({ kind: 'listen' as const, data: l, timestamp: l.playedAt })),
  ...githubActivity.map((g) => ({ kind: 'github' as const, data: g, timestamp: g.timestamp })),
].sort((a, b) => b.timestamp.getTime() - a.timestamp.getTime());

// pass health step data as JSON for client-side day grouping
const stepEvents = healthEvents
  .filter((h) => h.type === 'steps' && h.value)
  .map((h) => ({ timestamp: h.timestamp.toISOString(), value: Number(h.value) }));

// collapse consecutive listen runs (>3) into first + "x more" + last
// and merge consecutive identical github events
type DisplayItem =
  | TimelineItem
  | { kind: 'listen-collapsed'; first: TimelineItem; last: TimelineItem; hidden: TimelineItem[]; count: number; artistSummary: string }
  | { kind: 'github-merged'; data: GitHubEvent; timestamp: Date; count: number };

function collapseRuns(allItems: TimelineItem[]): DisplayItem[] {
  const result: DisplayItem[] = [];
  let i = 0;

  while (i < allItems.length) {
    if (allItems[i].kind === 'github') {
      const first = allItems[i];
      const g = first.data as GitHubEvent;
      let runEnd = i + 1;
      while (
        runEnd < allItems.length &&
        allItems[runEnd].kind === 'github' &&
        (allItems[runEnd].data as GitHubEvent).type === g.type &&
        (allItems[runEnd].data as GitHubEvent).description === g.description &&
        (allItems[runEnd].data as GitHubEvent).repo === g.repo
      ) {
        runEnd++;
      }
      const count = runEnd - i;
      if (count > 1) {
        result.push({ kind: 'github-merged', data: g, timestamp: first.timestamp, count });
      } else {
        result.push(first);
      }
      i = runEnd;
      continue;
    }

    if (allItems[i].kind !== 'listen') {
      result.push(allItems[i]);
      i++;
      continue;
    }

    // find the run of consecutive listens
    let runEnd = i;
    while (runEnd < allItems.length && allItems[runEnd].kind === 'listen') {
      runEnd++;
    }

    const runLength = runEnd - i;
    if (runLength > 3) {
      const hiddenItems = allItems.slice(i + 1, runEnd - 1);
      const seen = new Map<string, string>();
      for (const h of hiddenItems) {
        const names = (h as { data: SpotifyListen }).data.artist.split(', ');
        for (const name of names) {
          const key = name.toLowerCase().trim();
          if (!seen.has(key)) seen.set(key, name.trim());
        }
      }
      const artists = [...seen.values()];

      let artistSummary: string;
      if (artists.length === 1) {
        artistSummary = artists[0];
      } else if (artists.length === 2) {
        artistSummary = `${artists[0]} and ${artists[1]}`;
      } else {
        artistSummary = `${artists[0]}, ${artists[1]} and more`;
      }

      result.push({
        kind: 'listen-collapsed',
        first: allItems[i],
        last: allItems[runEnd - 1],
        hidden: hiddenItems,
        count: runLength - 2,
        artistSummary,
      });
    } else {
      for (let j = i; j < runEnd; j++) {
        result.push(allItems[j]);
      }
    }
    i = runEnd;
  }

  return result;
}

const displayItems = collapseRuns(items);

function shortRepo(full: string): string {
  return full.includes('/') ? full.split('/')[1] : full;
}

const ghActionIcon: Record<string, string> = {
  push:   '<path fill="currentColor" d="M4.75 7.25a.75.75 0 0 1 .75.75v5.25a.75.75 0 0 1-1.5 0V8a.75.75 0 0 1 .75-.75Zm0-5a.75.75 0 0 1 .53.22l2.5 2.5a.75.75 0 0 1-1.06 1.06L5.5 4.81V8a.75.75 0 0 1-1.5 0V4.81L2.78 6.03a.75.75 0 0 1-1.06-1.06l2.5-2.5a.75.75 0 0 1 .53-.22ZM11 2.5a.75.75 0 0 1 .75.75v5.25a.75.75 0 0 1-1.5 0V3.25A.75.75 0 0 1 11 2.5Zm.53 9.22a.75.75 0 0 1 0 1.06l-2.5 2.5a.75.75 0 0 1-1.06 0l-2.5-2.5a.75.75 0 1 1 1.06-1.06l1.22 1.22V8a.75.75 0 0 1 1.5 0v4.94l1.22-1.22a.75.75 0 0 1 1.06 0Z"/>',
  pr:     '<path fill="currentColor" d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/>',
  issue:  '<path fill="currentColor" d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/><path fill="currentColor" d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z"/>',
  star:   '<path fill="currentColor" d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>',
  create: '<path fill="currentColor" d="M11.75 2.5a.75.75 0 0 1 .75.75V11a.75.75 0 0 1-1.5 0V4.81L2.78 13.03a.75.75 0 0 1-1.06-1.06L9.94 3.75H4.75a.75.75 0 0 1 0-1.5h6.5a.75.75 0 0 1 .5.25Z"/>',
};


const spotifyLogo = '<path fill="#1DB954" d="M8 0a8 8 0 100 16A8 8 0 008 0zm3.67 11.54a.5.5 0 01-.68.16c-1.87-1.14-4.22-1.4-6.99-.77a.5.5 0 01-.22-.97c3.03-.69 5.63-.39 7.73.9a.5.5 0 01.16.68zm.98-2.18a.62.62 0 01-.85.2c-2.14-1.31-5.4-1.7-7.93-.93a.62.62 0 01-.36-1.19c2.9-.88 6.5-.45 8.94 1.06a.62.62 0 01.2.86zm.08-2.27C10.5 5.6 6.1 5.46 3.56 6.24a.75.75 0 01-.43-1.43c2.92-.9 7.77-.72 10.84 1.07a.75.75 0 01-.74 1.3l-.5-.09z"/>';
const githubLogo = '<path fill="#8b949e" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>';
---

<Base title="Activity" description="Recent activity.">
  <h1>activity</h1>
  <p class="page-desc">what i've been up to, automatically.</p>

  <script type="application/json" id="step-data" set:html={JSON.stringify(stepEvents)} />

  {items.length === 0 && (
    <div class="empty">
      <p class="dim">no activity data available.</p>
      <p class="dim hint">connect spotify or github to populate this page.</p>
    </div>
  )}

  {displayItems.length > 0 && (
    <div class="timeline">
      {displayItems.map((item) => {
        if (item.kind === 'listen') {
          const l = item.data;
          return (
            <a href={l.url} class="timeline-entry timeline-item" data-time={item.timestamp.toISOString()} target="_blank" rel="noopener">
              <span class="entry-icon">
                {l.albumArt ? (
                  <img src={l.albumArt} alt="" width="32" height="32" loading="lazy" />
                ) : (
                  <span class="icon-placeholder">♫</span>
                )}
              </span>
              <span class="entry-body">
                <span class="entry-primary">{l.track}</span>
                <span class="entry-secondary">{l.artist}</span>
              </span>
              <span class="entry-meta">
                <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                <time class="entry-time mono" data-time={item.timestamp.toISOString()}></time>
              </span>
            </a>
          );
        } else if (item.kind === 'github' || item.kind === 'github-merged') {
          const g = item.data;
          const count = item.kind === 'github-merged' ? item.count : 0;
          return (
            <a href={g.url} class="timeline-entry timeline-item" data-time={item.timestamp.toISOString()} target="_blank" rel="noopener">
              <span class="entry-icon gh-action-icon">
                <svg viewBox="0 0 16 16" width="16" height="16"><Fragment set:html={ghActionIcon[g.type] || ghActionIcon.push} /></svg>
              </span>
              <span class="entry-body">
                <span class="entry-primary">{g.description}{count > 1 && <span class="merge-count"> (x{count})</span>}</span>
                <span class="entry-secondary">{shortRepo(g.repo)}</span>
              </span>
              <span class="entry-meta">
                <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={githubLogo} /></svg>
                <time class="entry-time mono" data-time={item.timestamp.toISOString()}></time>
              </span>
            </a>
          );
        } else {
          // collapsed listen run
          const c = item;
          const first = c.first as { kind: 'listen'; data: SpotifyListen; timestamp: Date };
          const last = c.last as { kind: 'listen'; data: SpotifyListen; timestamp: Date };
          const fl = first.data;
          const ll = last.data;
          return (
            <div class="listen-group timeline-item" data-time={first.timestamp.toISOString()}>
              <a href={fl.url} class="timeline-entry" target="_blank" rel="noopener">
                <span class="entry-icon">
                  {fl.albumArt ? (
                    <img src={fl.albumArt} alt="" width="32" height="32" loading="lazy" />
                  ) : (
                    <span class="icon-placeholder">♫</span>
                  )}
                </span>
                <span class="entry-body">
                  <span class="entry-primary">{fl.track}</span>
                  <span class="entry-secondary">{fl.artist}</span>
                </span>
                <span class="entry-meta">
                  <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                  <time class="entry-time mono" data-time={first.timestamp.toISOString()}></time>
                </span>
              </a>

              <button class="listen-expand" data-expand>
                <span class="expand-label">+ {c.count} more featuring {c.artistSummary}</span>
              </button>

              <div class="listen-hidden" data-hidden>
                {c.hidden.map((h) => {
                  const hl = (h as { kind: 'listen'; data: SpotifyListen; timestamp: Date }).data;
                  return (
                    <a href={hl.url} class="timeline-entry" target="_blank" rel="noopener">
                      <span class="entry-icon">
                        {hl.albumArt ? (
                          <img src={hl.albumArt} alt="" width="32" height="32" loading="lazy" />
                        ) : (
                          <span class="icon-placeholder">♫</span>
                        )}
                      </span>
                      <span class="entry-body">
                        <span class="entry-primary">{hl.track}</span>
                        <span class="entry-secondary">{hl.artist}</span>
                      </span>
                      <span class="entry-meta">
                        <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                        <time class="entry-time mono" data-time={h.timestamp.toISOString()}></time>
                      </span>
                    </a>
                  );
                })}
              </div>

              <a href={ll.url} class="timeline-entry" target="_blank" rel="noopener">
                <span class="entry-icon">
                  {ll.albumArt ? (
                    <img src={ll.albumArt} alt="" width="32" height="32" loading="lazy" />
                  ) : (
                    <span class="icon-placeholder">♫</span>
                  )}
                </span>
                <span class="entry-body">
                  <span class="entry-primary">{ll.track}</span>
                  <span class="entry-secondary">{ll.artist}</span>
                </span>
                <span class="entry-meta">
                  <svg class="source-logo" viewBox="0 0 16 16" width="12" height="12"><Fragment set:html={spotifyLogo} /></svg>
                  <time class="entry-time mono" data-time={last.timestamp.toISOString()}></time>
                </span>
              </a>
            </div>
          );
        }
      })}
    </div>
  )}
</Base>

<style>
  h1 { margin-bottom: 0.5rem; }

  .page-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 3rem;
  }

  .empty {
    padding: 2rem 0;
  }

  .hint {
    font-size: 0.82rem;
    margin-top: 0.5rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* these elements are created dynamically in JS, so they need :global */
  :global(.timeline-day) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  :global(.day-label) {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    font-weight: 400;
    margin-bottom: 0.5rem;
    padding-left: 0.1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  :global(.day-steps) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  :global(.day-entries) {
    display: flex;
    flex-direction: column;
  }

  .timeline-entry {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: var(--text);
    transition: transform 0.12s ease, color 0.12s ease;
  }

  .timeline-entry:hover {
    transform: translateX(2px);
    color: var(--text-bright);
  }

  .timeline-entry:hover .entry-meta {
    opacity: 0.8;
  }

  .entry-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .entry-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }

  .gh-action-icon {
    color: var(--text-dim);
  }

  .merge-count {
    color: var(--text-dim);
    font-size: 0.8em;
  }

  .icon-placeholder {
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .entry-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .entry-primary {
    font-size: 0.88rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .entry-secondary {
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .entry-meta {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: opacity 0.12s ease;
  }

  .entry-time {
    font-size: 0.65rem;
    color: var(--text-dim);
  }

  .source-logo {
    opacity: 0.7;
  }

  .listen-group {
    display: flex;
    flex-direction: column;
  }

  .listen-expand {
    background: none;
    border: none;
    padding: 0.5rem 0;
    margin-left: 2.85rem;
    font-size: 0.72rem;
    color: var(--text-dim);
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    transition: color 0.12s ease;
  }

  .listen-expand:hover {
    color: var(--text);
  }

  .expand-dots {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
  }

  .expand-label {
    font-size: 0.72rem;
  }

  .listen-hidden {
    display: none;
    flex-direction: column;
  }

  .listen-hidden.expanded {
    display: flex;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // format times in local timezone
    document.querySelectorAll<HTMLTimeElement>('time[data-time]').forEach((el) => {
      const iso = el.getAttribute('data-time');
      if (!iso) return;
      const date = new Date(iso);
      el.textContent = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }).toLowerCase();
    });

    // group items by local day and insert day headers
    const timeline = document.querySelector('.timeline');
    if (!timeline) return;

    const items = Array.from(timeline.querySelectorAll<HTMLElement>('.timeline-item'));
    if (items.length === 0) return;

    // parse step data for day totals
    const stepDataEl = document.getElementById('step-data');
    const stepEvents: { timestamp: string; value: number }[] = stepDataEl ? JSON.parse(stepDataEl.textContent || '[]') : [];
    const stepsByLocalDay = new Map<string, number>();
    for (const s of stepEvents) {
      const localDate = new Date(s.timestamp).toLocaleDateString('en-CA'); // YYYY-MM-DD
      stepsByLocalDay.set(localDate, (stepsByLocalDay.get(localDate) || 0) + s.value);
    }

    function relativeDay(date: Date): string {
      const now = new Date();
      const todayStr = now.toLocaleDateString('en-CA');
      const yesterdayDate = new Date(now);
      yesterdayDate.setDate(yesterdayDate.getDate() - 1);
      const yesterdayStr = yesterdayDate.toLocaleDateString('en-CA');
      const dateStr = date.toLocaleDateString('en-CA');

      if (dateStr === todayStr) return 'today';
      if (dateStr === yesterdayStr) return 'yesterday';

      const diff = Math.floor((now.getTime() - date.getTime()) / (1000 * 60 * 60 * 24));
      if (diff < 7) return `${diff} days ago`;
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toLowerCase();
    }

    const stepsSvg = '<svg viewBox="0 0 16 16" width="11" height="11"><path fill="currentColor" d="M4.5 2a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm2.4 5.55L5.15 13.3a.75.75 0 0 1-1.4-.53l1.5-4.87L4 9v2.25a.75.75 0 0 1-1.5 0V8.7a.75.75 0 0 1 .15-.45l2.1-2.7a1.5 1.5 0 0 1 2.35-.1l1.05 1.3a3.76 3.76 0 0 0 2.1 1.3.75.75 0 0 1-.35 1.45 5.25 5.25 0 0 1-2.95-1.95Z"/></svg>';

    // group items by local date
    const groups: { dateKey: string; label: string; elements: HTMLElement[] }[] = [];
    for (const el of items) {
      const iso = el.getAttribute('data-time');
      if (!iso) continue;
      const date = new Date(iso);
      const dateKey = date.toLocaleDateString('en-CA');
      const label = relativeDay(date);
      const last = groups[groups.length - 1];
      if (last && last.dateKey === dateKey) {
        last.elements.push(el);
      } else {
        groups.push({ dateKey, label, elements: [el] });
      }
    }

    // rebuild timeline with day sections
    timeline.innerHTML = '';
    for (const group of groups) {
      const section = document.createElement('section');
      section.className = 'timeline-day';

      let headerHTML = group.label;
      const steps = stepsByLocalDay.get(group.dateKey);
      if (steps) {
        headerHTML += `<span class="day-steps">${stepsSvg} ${steps.toLocaleString()}</span>`;
      }

      const h2 = document.createElement('h2');
      h2.className = 'day-label mono';
      h2.innerHTML = headerHTML;

      const entries = document.createElement('div');
      entries.className = 'day-entries';
      for (const el of group.elements) {
        entries.appendChild(el);
      }

      section.appendChild(h2);
      section.appendChild(entries);
      timeline.appendChild(section);
    }

    // listen expand toggles
    document.querySelectorAll('[data-expand]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const hidden = btn.nextElementSibling as HTMLElement;
        if (hidden?.classList.contains('expanded')) {
          hidden.classList.remove('expanded');
          (btn as HTMLElement).style.display = '';
        } else {
          hidden?.classList.add('expanded');
          (btn as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
