---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('notes'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<Base title="Notes" description="Short observations and quick thoughts.">
  <h1 class="page-title">notes</h1>
  <p class="page-desc">short thoughts, 280 characters or less.</p>

  <div class="h-feed timeline">
    <span class="p-name" hidden>notes</span>
    <div class="p-author h-card" hidden>
      <img class="u-photo" src="/avatar.png" alt="rhg" />
      <a class="p-name u-url" href="https://rhg.sh">rhg</a>
    </div>
    {rendered.map(({ entry, Content }) => (
      <article class="h-entry timeline-entry">
        <div class="timeline-date mono">
          <FormattedDate date={entry.data.date} class="dt-published" />
        </div>
        {/* No p-name — notes, not articles */}
        <div class="e-content timeline-content prose">
          <Content />
        </div>
        <a class="u-url" href={`/notes/${entry.id}/`} hidden></a>
      </article>
    ))}
  </div>
</Base>

<style>
  h1 { margin-bottom: 0.5rem; }

  .page-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 3rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border);
    margin-left: 0.25rem;
    padding-left: 1.75rem;
    gap: 2.5rem;
  }

  .timeline-entry {
    position: relative;
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: calc(-1.75rem - 3px);
    top: 0.35rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-dim);
    opacity: 0.3;
  }

  .timeline-date {
    font-size: 0.68rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }

  .timeline-content {
    text-transform: lowercase;
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .timeline-content :global(p:first-child) {
    margin-top: 0;
  }

</style>
