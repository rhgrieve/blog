{
  "name": "timeline-worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create timeline-db",
    "db:migrate": "wrangler d1 execute timeline-db --file=./schema.sql",
    "db:migrate:prod": "wrangler d1 execute timeline-db --file=./schema.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.76.0"
  }
}
